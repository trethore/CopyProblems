<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.trethore.copyproblems</id>
    <name>CopyProblems</name>
    <vendor>trethore</vendor>
    <description><![CDATA[
        <p>Copy problems from IntelliJ IDEA's Problems tool window with their file, line, column, and severity.</p>
    ]]></description>

    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable id="copyproblems.settings"
                                 displayName="CopyProblems"
                                 parentId="tools"
                                 instance="com.github.trethore.copyproblems.settings.CopyProblemsConfigurable"/>
    </extensions>

    <actions>
        <group id="CopyProblems.PopupGroup" popup="false">
            <action id="CopyProblems.CopyProblem"
                    class="com.github.trethore.copyproblems.actions.CopyProblemAction"
                    text="Copy Problem with Location"/>
            <action id="CopyProblems.CopySelection"
                    class="com.github.trethore.copyproblems.actions.CopySelectedNodeProblemsAction"
                    text="Copy Problems in Selected Node"/>
            <action id="CopyProblems.CopyAllVisible"
                    class="com.github.trethore.copyproblems.actions.CopyAllVisibleProblemsAction"
                    text="Copy All Visible Problems"/>
            <separator/>
            <action id="CopyProblems.CopyMinimumSeverity"
                    class="com.github.trethore.copyproblems.actions.CopyMinimumSeverityAction"
                    text="Copy Problems at Minimum Severity"/>
            <add-to-group group-id="ProblemsView.ToolWindow.TreePopup" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
